API_V1_PREFIX = "/api/v1"

CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]
# 필수 설정
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
TRIAGE_MODEL=gpt-4.1-nano
SEARCH_SUMMARIZER_MODEL=gpt-4.1-mini
SEARCH_SUMMARIZER_ENABLED=true
SEARCH_SUMMARIZER_MAX_DOCS=3
SEARCH_SUMMARIZER_MAX_CHARS_PER_DOC=800
SEARCH_SUMMARIZER_MAX_OUTPUT_TOKENS=350
ELASTICSEARCH_URL=https://elasticsearch-edu.didim365.app
ELASTICSEARCH_INDEX=edu-collection
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password
ELASTICSEARCH_TOP_K=3
HOSPITAL_ELASTICSEARCH_INDEX=
HOSPITAL_SEARCH_FIELDS=["name", "address", "department", "description"]

# DeepAgents 설정
DEEPAGENT_RECURSION_LIMIT=20

# Opik 설정
OPIK__URL_OVERRIDE=
OPIK__API_KEY=
OPIK__WORKSPACE=
OPIK__PROJECT=
OPIK__DATASET=lyp-dataset-edu
